{
  "name": "sandbox-website-template",
  "description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
  "private": true,
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@radix-ui/react-slot": "^1.2.4",
    "@runablehq/website-runtime": "^0.10.0",
    "ai": "^6.0.116",
    "atmn": "1.1.8",
    "autumn-js": "1.2.0",
    "better-auth": "1.4.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dedent": "^1.7.2",
    "drizzle-orm": "^0.45.1",
    "hono": "4.12.5",
    "lucide-react": "^0.577.0",
    "mathjs": "^15.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "runable-website-runtime": "^0.0.14",
    "tailwind-merge": "^3.5.0",
    "wouter": "^3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260306.1",
    "@vitejs/plugin-react": "5.1.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "10.0.3",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  },
  "scripts": {
    "build": "tsgo && ([ ! -f autumn.config.ts ] || bunx tsc --noEmit --skipLibCheck autumn.config.ts) && vite build",
    "cf-typegen": "wrangler types",
    "check": "tsgo && vite build && wrangler deploy --dry-run",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "bun run build && vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:studio": "drizzle-kit studio"
  },
  "type": "module"
}
